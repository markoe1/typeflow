# ────────────────────────────────────────────────────────────
# TypeFlow Admin Backend Configuration
# ────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3001

# ── Admin Authentication ────────────────────────────────────
# Generate a strong API key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=replace_with_strong_api_key_here

# ── Google APIs Configuration ──────────────────────────────
# Get service account credentials from Google Cloud Console:
# https://console.cloud.google.com/iam-admin/serviceaccounts

# AdSense account ID (found in AdSense dashboard, format: ca-pub-XXXXX)
ADSENSE_ACCOUNT_ID=ca-pub-3527398386713452

# GA4 Property ID (from Google Analytics, format: "properties/123456789")
GA4_PROPERTY_ID=properties/YOUR_GA4_PROPERTY_ID

# Full Google service account JSON (as a single-line JSON string)
# Must have scopes: adsense.readonly, analytics.readonly
# Format example (all on one line):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── PayPal Integration ──────────────────────────────────
# Get from: https://developer.paypal.com → Apps & Credentials
# Your PayPal Business Account: elliott@elegantsolarinc.com
PAYPAL_CLIENT_ID=replace_with_your_paypal_client_id
PAYPAL_SECRET=replace_with_your_paypal_secret
PAYPAL_MODE=sandbox
