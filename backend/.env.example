# TypeFlow Backend Configuration

# Server
PORT=3001

# Admin Authentication
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# Google APIs (for AdSense + GA4)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# AdSense
ADSENSE_ACCOUNT_ID=ca-pub-XXXXXXXXXX

# Google Analytics 4
GA4_PROPERTY_ID=properties/XXXXXXXXXX

# PayPal (if using payment integration)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox

# CORS - comma-separated allowed origins
ALLOWED_ORIGINS=https://example.com,https://www.example.com,http://localhost:5500

# Logging
LOG_LEVEL=INFO
