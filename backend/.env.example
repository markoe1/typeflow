# ═════════════════════════════════════════════════════════════════════════════
# TYPEFLOW BACKEND CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# SERVER CONFIGURATION (REQUIRED)
PORT=3001
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ADMIN AUTHENTICATION (REQUIRED - USE STRONG CREDENTIALS)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_to_very_strong_password_min_16_chars

# GOOGLE APIS (REQUIRED)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
ADSENSE_ACCOUNT_ID=ca-pub-XXXXXXXXXX
GA4_PROPERTY_ID=properties/XXXXXXXXXX

# PAYMENT PROCESSING (Optional - Stripe)
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXX

# PAYMENT PROCESSING (Optional - PayPal)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox  # or: live

# ENVIRONMENT
ENVIRONMENT=production  # development or production
DEBUG=false

# DEPLOYMENT
LOG_LEVEL=info
NODE_ENV=production
# TypeFlow Backend Configuration

# Server
PORT=3001

# Admin Authentication
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# Google APIs (for AdSense + GA4)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# AdSense
ADSENSE_ACCOUNT_ID=ca-pub-XXXXXXXXXX

# Google Analytics 4
GA4_PROPERTY_ID=properties/XXXXXXXXXX

# PayPal (if using payment integration)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox

# CORS - comma-separated allowed origins
ALLOWED_ORIGINS=https://example.com,https://www.example.com,http://localhost:5500

# Logging
LOG_LEVEL=INFO
